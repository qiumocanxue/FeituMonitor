<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="基本信息"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/feitu_blue"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="医院名称"
            app:boxStrokeColor="@color/feitu_blue"
            app:hintTextColor="@color/feitu_blue">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_hospital_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/black"
                android:padding="12dp"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="医院编码 (hscod)"
            app:boxStrokeColor="@color/feitu_blue"
            app:hintTextColor="@color/feitu_blue">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_hscod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/black"
                android:padding="12dp"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AES 加密配置 (二维码)"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/feitu_blue"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AES Key"
            app:boxStrokeColor="@color/feitu_blue"
            app:hintTextColor="@color/feitu_blue">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_aes_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/black"
                android:padding="12dp"
                android:fontFamily="monospace"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="AES IV"
            app:boxStrokeColor="@color/feitu_blue"
            app:hintTextColor="@color/feitu_blue">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_aes_iv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/black"
                android:padding="12dp"
                android:fontFamily="monospace"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="API 接口配置 (公众号)"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/feitu_blue"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Access Key"
            app:boxStrokeColor="@color/feitu_blue"
            app:hintTextColor="@color/feitu_blue">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_access_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/black"
                android:padding="12dp"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Access Secret"
            app:boxStrokeColor="@color/feitu_blue"
            app:hintTextColor="@color/feitu_blue">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_access_secret"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/black"
                android:padding="12dp"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>